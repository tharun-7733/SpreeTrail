// =============================================================================
// SpreeTail — schema.prisma
// Source of truth: DECISIONS.md (45 decisions) + SCOPE.md
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum SplitType {
  EQUAL
  UNEQUAL
  PERCENTAGE
  SHARES
}

enum GroupRole {
  ADMIN
  MEMBER
}

/// Decision 18: Expense vs Refund (import only)
enum TransactionType {
  EXPENSE
  REFUND
}

/// Decision 16: Manual vs Imported — drives mutability rules
enum ExpenseSource {
  MANUAL
  IMPORTED
}

/// Decision 24: Import session lifecycle
enum ImportSessionStatus {
  PARSING
  ANOMALY_REVIEW
  COMMITTING
  COMPLETED
  FAILED
}

/// Decision 21/22: Per-row resolution outcome
enum ImportRowStatus {
  PENDING
  APPROVED
  SKIPPED
}

/// Decision 22: What entity did the row become
enum ResolvedAs {
  EXPENSE
  REFUND
  SETTLEMENT
  SKIPPED
}

/// Decision 23: Anomaly category taxonomy
enum AnomalyType {
  DUPLICATE_EXPENSE
  NEGATIVE_AMOUNT
  MISSING_PAYER
  MISSING_CURRENCY
  UNKNOWN_MEMBER
  INACTIVE_MEMBER_AT_DATE
  AMBIGUOUS_DATE
  INVALID_SPLIT_TYPE
  PERCENTAGE_SUM_INVALID
  SETTLEMENT_AS_EXPENSE
  ZERO_AMOUNT
  MISSING_DESCRIPTION
}

// =============================================================================
// TABLE: User
// Decision 10: isActive gates new actions, never historical balance queries
// =============================================================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  groupMemberships      GroupMember[]
  groupsCreated         Group[]              @relation("GroupCreator")
  expensesPaid          Expense[]            @relation("ExpensePayer")
  expensesCreated       Expense[]            @relation("ExpenseCreator")
  expenseParticipations ExpenseParticipant[]
  settlementsPaid       Settlement[]         @relation("SettlementPayer")
  settlementsReceived   Settlement[]         @relation("SettlementReceiver")
  comments              ExpenseComment[]
  guestsCreated         GuestParticipant[]
  importSessions        ImportSession[]
  importRowApprovals    ImportedExpenseRaw[]

  @@map("users")
}

// =============================================================================
// TABLE: Group
// Decision: baseCurrency is the canonical currency for balance calculations
// =============================================================================

model Group {
  id           String   @id @default(uuid())
  name         String
  description  String?
  baseCurrency String   @default("INR")
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdBy        User               @relation("GroupCreator", fields: [createdById], references: [id])
  members          GroupMember[]
  expenses         Expense[]
  settlements      Settlement[]
  guests           GuestParticipant[]
  importSessions   ImportSession[]

  @@map("groups")
}

// =============================================================================
// TABLE: GroupMember
// Decision 11: joinedAt + leftAt stored here, group-specific
// Decision 27: Membership window used in SQL balance queries
// =============================================================================

model GroupMember {
  id       String    @id @default(uuid())
  groupId  String
  userId   String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())
  leftAt   DateTime? // null = still active

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

// =============================================================================
// TABLE: GuestParticipant
// Decision 14: Non-authenticated participants (e.g. Kabir)
// Constraint: groupId-scoped — cannot be used in another group
// =============================================================================

model GuestParticipant {
  id            String   @id @default(uuid())
  name          String
  groupId       String
  createdByUserId String
  createdAt     DateTime @default(now())

  group         Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy     User                @relation(fields: [createdByUserId], references: [id])
  participations ExpenseParticipant[]

  @@map("guest_participants")
}

// =============================================================================
// TABLE: Expense
// Decision 16: source drives mutability. imported = immutable.
// Decision 18: transactionType REFUND only via importer
// Decision 20: originalAmount/currency/exchangeRate/convertedAmountINR for multi-currency
// Decision 5: soft-delete via deletedAt. Never hard delete.
// =============================================================================

model Expense {
  id                  String          @id @default(uuid())
  groupId             String
  paidById            String
  createdById         String
  description         String
  amount              Decimal
  currency            String          @default("INR")
  originalAmount      Decimal?        // non-null when currency != baseCurrency
  originalCurrency    String?
  exchangeRate        Decimal?        // user-supplied at import time
  convertedAmountINR  Decimal?        // = amount if INR, else originalAmount * exchangeRate
  splitType           SplitType
  transactionType     TransactionType @default(EXPENSE)
  source              ExpenseSource   @default(MANUAL)
  date                DateTime        @default(now())
  deletedAt           DateTime?       // soft delete — Decision 5
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  group        Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy       User                @relation("ExpensePayer", fields: [paidById], references: [id])
  createdBy    User                @relation("ExpenseCreator", fields: [createdById], references: [id])
  participants ExpenseParticipant[]
  comments     ExpenseComment[]
  @@map("expenses")
}

// =============================================================================
// TABLE: ExpenseParticipant
// Decision 14: Supports both User and GuestParticipant (exactly one non-null)
// =============================================================================

model ExpenseParticipant {
  id                 String  @id @default(uuid())
  expenseId          String
  userId             String?  // nullable — null for guests
  guestParticipantId String?  // nullable — null for authenticated users
  shareAmount        Decimal
  sharePercentage    Decimal?
  shareUnits         Int?

  expense          Expense           @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user             User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestParticipant GuestParticipant? @relation(fields: [guestParticipantId], references: [id])

  // A participant (user or guest) can only appear once per expense
  @@unique([expenseId, userId])
  @@map("expense_participants")
}

// =============================================================================
// TABLE: Settlement
// Decision 29: Settlements applied dynamically at query time, not mutations
// soft-delete via deletedAt
// =============================================================================

model Settlement {
  id         String    @id @default(uuid())
  groupId    String
  payerId    String
  receiverId String
  amount     Decimal
  currency   String    @default("INR")
  note       String?
  settledAt  DateTime  @default(now())
  deletedAt  DateTime? // soft delete
  createdAt  DateTime  @default(now())

  group    Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  payer    User  @relation("SettlementPayer", fields: [payerId], references: [id])
  receiver User  @relation("SettlementReceiver", fields: [receiverId], references: [id])

  @@map("settlements")
}

// =============================================================================
// TABLE: ExpenseComment
// =============================================================================

model ExpenseComment {
  id        String   @id @default(uuid())
  expenseId String
  userId    String
  content   String
  createdAt DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("expense_comments")
}

// =============================================================================
// TABLE: ImportSession
// Decision 24: Resumable sessions. Status tracks progress.
// Decision 25: Report is derived from session + rows, not stored separately.
// =============================================================================

model ImportSession {
  id                String              @id @default(uuid())
  groupId           String
  importedByUserId  String
  filename          String
  status            ImportSessionStatus @default(PARSING)
  totalRows         Int                 @default(0)
  rowsCommitted     Int                 @default(0)
  rowsSkipped       Int                 @default(0)
  rowsPendingReview Int                 @default(0)
  createdAt         DateTime            @default(now())
  completedAt       DateTime?

  group        Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  importedBy   User                 @relation(fields: [importedByUserId], references: [id])
  rows         ImportedExpenseRaw[]

  @@map("import_sessions")
}

// =============================================================================
// TABLE: ImportedExpenseRaw
// Decision 19: rawData always preserved. Never overwritten.
// Decision 22: resolvedAs tracks final entity type.
// Decision 21: createdEntityId enables idempotency check before re-committing.
// =============================================================================

model ImportedExpenseRaw {
  id                   String          @id @default(uuid())
  importSessionId      String
  rowNumber            Int
  rawData              Json            // original CSV row fields, verbatim
  resolvedData         Json?           // user-corrected values after anomaly review
  anomalies            Json?           // array of { anomalyType, severity, field, rawValue }
  status               ImportRowStatus @default(PENDING)
  resolvedAs           ResolvedAs?     // set when committed
  // Idempotency: stores the ID of the committed entity. Check before re-committing.
  // resolvedAs tells us which table to look in.
  committedEntityId    String?         // Expense.id or Settlement.id (app-layer FK, no DB constraint)
  approvedById         String?
  approvedAt           DateTime?
  resolutionNote       String?
  createdAt            DateTime        @default(now())

  importSession ImportSession @relation(fields: [importSessionId], references: [id], onDelete: Cascade)
  approvedBy    User?         @relation(fields: [approvedById], references: [id])

  @@unique([importSessionId, rowNumber])
  @@map("imported_expense_raw")
}
